# ──────────────────────────────────────────────
# ShadowAuth-ZK Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Transport mode: icmp | dns
SHADOWAUTH_TRANSPORT=icmp

# Server bind address
SHADOWAUTH_SERVER_HOST=0.0.0.0

# DNS tunnel domain (only for dns transport)
SHADOWAUTH_DNS_DOMAIN=example.com

# Merkle tree depth
SHADOWAUTH_TREE_DEPTH=20

# Path to trusted setup artifacts
SHADOWAUTH_ZKEY_PATH=circuits/build/ShadowAuth_final.zkey
SHADOWAUTH_WASM_PATH=circuits/build/ShadowAuth_js/ShadowAuth.wasm
SHADOWAUTH_VKEY_PATH=circuits/build/verification_key.json

# Logging level: DEBUG | INFO | WARNING | ERROR
SHADOWAUTH_LOG_LEVEL=INFO
